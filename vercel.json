{
  "version": 2,
  "builds": [
    {
      "src": "demo/portal/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/styles.css",
      "dest": "demo/portal/styles.css"
    },
    {
      "src": "/app.js",
      "dest": "demo/portal/app.js"
    },
    {
      "src": "/(.*)",
      "dest": "demo/portal/index.html"
    }
  ]
}
